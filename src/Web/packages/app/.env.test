# Test environment for frontend

PUBLIC_API_URL=http://localhost:1612
VITE_ENV=test

# WebSocket configuration (bridge is integrated into SvelteKit server)
PUBLIC_WEBSOCKET_RECONNECT_ATTEMPTS=5
PUBLIC_WEBSOCKET_MAX_RECONNECT_DELAY=30000
PUBLIC_WEBSOCKET_RECONNECT_DELAY=1000
PUBLIC_WEBSOCKET_PING_TIMEOUT=15000
PUBLIC_WEBSOCKET_PING_INTERVAL=20000

# Instance key for service authentication (server-side only)
# Must match the instance key configured in the Nocturne API
INSTANCE_KEY=NightscoutSecretKeyForJWTGenerationShouldBeAtLeast32Characters